# ═══════════════════════════════════════════════════════════════
# JARVIS v7 — Environment Variables
# ═══════════════════════════════════════════════════════════════
# HOW TO USE:
#   1. Copy: cp .env.example .env.local
#   2. Fill in actual keys (.env.local is gitignored)
#   3. Restart: npm run dev
#
# ✓ FREE = no credit card needed
# ★ REQUIRED = app won't work without this
# ★★ NEW in v7 = fresh upgrade, highly recommended
# ═══════════════════════════════════════════════════════════════

# ── APP ─────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── SUPABASE ★ REQUIRED ─────────────────────────────────────────
# supabase.com → Project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── GEMINI AI ★ REQUIRED | ✓ FREE ──────────────────────────────
# aistudio.google.com → Get API Key | 1M tokens/day free
# v7: Now using gemini-2.5-flash-preview (upgraded from 1.5)
GEMINI_API_KEY=AIzaSy...

# ── GROQ ★ REQUIRED | ✓ FREE ────────────────────────────────────
# console.groq.com → API Keys | Ultra fast, 14400 req/day free
# v7: Also used for Whisper STT (free voice transcription!)
GROQ_API_KEY=gsk_...

# ── OPENROUTER | ✓ FREE MODELS AVAILABLE ────────────────────────
# openrouter.ai → Keys | 4th level fallback
OPENROUTER_KEY=sk-or-...

# ── CEREBRAS ★★ NEW | ✓ FREE ─────────────────────────────────────
# cerebras.ai → API Keys | 3000 tokens/sec — fastest LLM available
# Used for: ReAct agent reasoning + 1st fallback model
CEREBRAS_API_KEY=
# cerebras.ai → Dashboard → API Keys → 3000 tokens/sec, FREE tier

# ── SAMBANOVA (v8 NEW) ────────────────────────────────────────
# cloud.sambanova.ai → API Keys → FREE tier, 919 t/s, OpenAI-compatible
# 3rd in fallback chain after Cerebras
SAMBANOVA_API_KEY=csk-...

# ── TAVILY SEARCH ★★ NEW | ✓ FREE ───────────────────────────────
# tavily.com → API Keys | 1000 searches/month free
# Used for: JARVIS internet search in Deep mode (ReAct agent)
TAVILY_API_KEY=tvly-...

# ── SARVAM AI ★★ NEW | ✓ FREE | 🇮🇳 Made in India ───────────────
# sarvam.ai → Sign up → API Key
# Used for: Best Hindi/Hinglish TTS + STT (11 Indian languages!)
# Chain: Sarvam (primary) → ElevenLabs → Google TTS → Browser
SARVAM_API_KEY=

# ── HUGGINGFACE | ✓ FREE ─────────────────────────────────────────
# huggingface.co → Settings → Access Tokens
HUGGINGFACE_TOKEN=hf_...

# ── TTS — TEXT TO SPEECH ─────────────────────────────────────────
# ElevenLabs — 10k chars/month free (2nd in chain after Sarvam)
ELEVENLABS_API_KEY=
# Google Cloud TTS — WaveNet Hindi voices
GOOGLE_TTS_KEY=
# Azure TTS — hi-IN-SwaraNeural
AZURE_TTS_KEY=
AZURE_REGION=eastus
# Fish Audio — voice cloning
FISH_AUDIO_KEY=

# ── IMAGE GENERATION ─────────────────────────────────────────────
AIMLAPI_KEY=
FAL_API_KEY=
LEONARDO_API_KEY=
DEEPAI_KEY=

# ── VIDEO GENERATION ─────────────────────────────────────────────
LUMA_API_KEY=
KLING_API_KEY=
HAILUO_API_KEY=
HAILUO_GROUP_ID=

# ── MUSIC GENERATION ─────────────────────────────────────────────
MUBERT_API_KEY=

# ── NEWS APIs ────────────────────────────────────────────────────
NEWSDATA_KEY=
GNEWS_API_KEY=

# ── VERCEL CRON (v8 NEW) ─────────────────────────────────────
# Random secret string to protect cron endpoint
# Generate: openssl rand -hex 32
CRON_SECRET=your_random_secret_here

# ── PUSH NOTIFICATIONS (VAPID) ───────────────────────────────
# Run: node scripts/generate-vapid.js → paste output here
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:your@email.com

# ── OAUTH / SOCIAL ───────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
META_APP_ID=
META_APP_SECRET=
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# ── FREE APIs (No key needed) ─────────────────────────────────────
# Weather: open-meteo.com | Quotes: quotable.io | Jokes: jokeapi.dev
# Images:  pollinations.ai (fallback) | Weather: open-meteo.com

